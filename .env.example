# Docker Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# LLM Provider Selection
# ===========================================
# Options: "cloud" (OpenAI) or "local" (Ollama)
LLM_PROVIDER=cloud

# ===========================================
# Cloud LLM API Keys (required if LLM_PROVIDER=cloud)
# ===========================================
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key (optional)
ANTHROPIC_API_KEY=

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ===========================================
# Model Configuration
# ===========================================
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# ===========================================
# Local LLM Settings (if LLM_PROVIDER=local)
# ===========================================
# Install Ollama: https://ollama.ai
# Then run: ollama pull llama3.1:8b
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=llama3.1:8b

# ===========================================
# RAG Backend Settings
# ===========================================
# Set to true to clear the vector database on startup (development only)
CLEAR_DB_ON_START=false
