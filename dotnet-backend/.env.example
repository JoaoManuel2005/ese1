# .env.example — copy to .env and fill in your values
FEATURE_SHAREPOINT_ENRICHMENT=false

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "cloud" = OpenAI / Azure OpenAI  |  "local" = Ollama
LLM_PROVIDER=cloud

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=2CgkGjGkGvg2uPOd5DOd1wxZZmXBfPh8EnQLrdAYooM58QvbGdsjJQQJ99CBACPVOroXJ3w3AAAAACOGk1fo
AZURE_OPENAI_ENDPOINT=https://uofg-team-project-ese1-resource2.openai.azure.com/openai/v1/
OPENAI_MODEL=gpt4.1

# Used for embeddings (must be deployed in your Azure OpenAI resource)
EMBEDDING_MODEL=text-embedding-ada-002

# ── Embedding Provider ────────────────────────────────────────────────────────
# "bge" = Free local BGE model (requires Python service)  |  "azure" = Azure OpenAI embeddings
EMBEDDING_PROVIDER=bge

# BGE Embedding Service URL (Python FastAPI service with sentence-transformers)
BGE_SERVICE_URL=http://localhost:8002

# ── Local (Ollama) ─────────────────────────────────────────────────────────────
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b
