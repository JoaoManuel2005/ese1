# Cloud provider (default)
OPENAI_API_KEY=your-openai-key
# Optional: override cloud model (fallback remains gpt-4 if unset)
# OPENAI_MODEL=gpt-4

# Provider selection: cloud (default) or local
# LLM_PROVIDER=cloud

# Local provider settings (for Ollama or compatible HTTP chat API)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b

# Chroma DB path
# CHROMA_DB_PATH=./rag_chroma_db
